generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                 Int              @id @default(autoincrement())
  name               String?
  email              String?          @unique
  password           String?
  googleId           String?          @unique
  avatar             String?
  qualification      String?
  state              String?
  interests          String?
  availableStudyTime Int?             @default(0)
  age                Int?
  studyStreak        Int              @default(0)
  longestStreak      Int              @default(0)
  totalStudyHours    Float            @default(0)
  todayStudyMinutes  Int              @default(0)
  weeklyStudyMinutes Int              @default(0)
  monthlyStudyMinutes Int             @default(0)
  xpPoints           Int              @default(0)
  level              Int              @default(1)
  lastStudyDate      DateTime?
  streakFreeze       Int              @default(0)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  studyPlans         StudyPlan[]
  notes              Note[]
  studySessions      StudySession[]
  testResults        TestResult[]
  streakHistory      StreakHistory[]
  revisionPlans      RevisionPlan[]
  weakAreas          WeakArea[]
  achievements       Achievement[]
  notifications      Notification[]
  bookmarks          Bookmark[]
}

model Job {
  id              Int       @id @default(autoincrement())
  title           String
  organization    String
  category        String
  subcategory     String?
  description     String?
  eligibility     String?
  ageLimit        String?
  salary          String?
  selectionProcess String?
  examPattern     String?
  vacancies       String?
  officialWebsite String?
  applyLink       String?
  examDate        DateTime?
  lastDate        DateTime?
  cutoffs         String?
  previousYearTrends String?
  importantDates  String?
  status          String?   @default("active")
  createdAt       DateTime  @default(now())
}

model StudyPlan {
  id        Int      @id @default(autoincrement())
  userId    Int
  exam      String
  examDate  DateTime
  planType  String   @default("auto")
  planJson  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Note {
  id        Int      @id @default(autoincrement())
  userId    Int
  title     String
  content   String
  subject   String?
  tags      String?
  color     String?  @default("blue")
  isPinned  Boolean  @default(false)
  aiSummary String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
}

model StudySession {
  id        Int      @id @default(autoincrement())
  userId    Int
  duration  Int
  type      String   @default("pomodoro")
  subject   String?
  focusScore Int?    @default(0)
  date      DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model MockTest {
  id             Int      @id @default(autoincrement())
  title          String
  subject        String?
  category       String?
  duration       Int      @default(60)
  totalMarks     Int      @default(100)
  totalQuestions Int      @default(50)
  questions      String
  isSectional    Boolean  @default(false)
  isPreviousYear Boolean  @default(false)
  difficulty     String?  @default("medium")
  createdAt      DateTime @default(now())
}

model TestResult {
  id              Int      @id @default(autoincrement())
  userId          Int
  testId          Int
  score           Int
  totalMarks      Int
  correctAnswers  Int
  incorrectAnswers Int
  unanswered      Int
  timeTaken       Int
  subjectWiseScores String?
  answers         String?
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id])
}

model StreakHistory {
  id      Int      @id @default(autoincrement())
  userId  Int
  date    DateTime
  studied Boolean  @default(false)
  minutes Int      @default(0)
  user    User     @relation(fields: [userId], references: [id])

  @@unique([userId, date])
}

model RevisionPlan {
  id        Int      @id @default(autoincrement())
  userId    Int
  planType  String
  planJson  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model WeakArea {
  id          Int      @id @default(autoincrement())
  userId      Int
  subject     String
  topic       String?
  score       Float?
  suggestions String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])
}

model Achievement {
  id         Int      @id @default(autoincrement())
  userId     Int
  badge      String
  description String
  xpRewarded Int      @default(0)
  unlockedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  type      String
  title     String
  message   String
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Bookmark {
  id          Int      @id @default(autoincrement())
  userId      Int
  type        String
  referenceId Int
  title       String?
  url         String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
}

model CurrentAffair {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  category    String?
  date        DateTime
  source      String?
  url         String?
  tags        String?
  createdAt   DateTime @default(now())
}

model ChatHistory {
  id        Int      @id @default(autoincrement())
  userId    Int
  message   String
  response  String
  createdAt DateTime @default(now())
}

model Syllabus {
  id         Int      @id @default(autoincrement())
  exam       String
  subject    String
  topic      String
  subtopics  String?
  weightage  Float?
  difficulty String?  @default("medium")
  orderIndex Int      @default(0)
}
