generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                Int            @id @default(autoincrement())
  name              String?        @db.VarChar(255)
  email             String?        @unique @db.VarChar(255)
  password          String?        @db.VarChar(500)
  googleId          String?        @unique @db.VarChar(255)
  avatar            String?        @db.VarChar(500)
  qualification     String?        @db.VarChar(100)
  state             String?        @db.VarChar(100)
  interests         String?        @db.VarChar(500)
  availableStudyTime Int?          @default(0)
  age               Int?
  studyStreak       Int            @default(0)
  longestStreak     Int            @default(0)
  totalStudyHours   Float          @default(0)
  todayStudyMinutes Int            @default(0)
  weeklyStudyMinutes Int           @default(0)
  monthlyStudyMinutes Int          @default(0)
  xpPoints          Int            @default(0)
  level             Int            @default(1)
  lastStudyDate     DateTime?
  streakFreeze      Int            @default(0)
  createdAt         DateTime?      @default(now()) @db.Timestamp(6)
  updatedAt         DateTime?      @updatedAt

  studyPlans        StudyPlan[]
  notes             Note[]
  studySessions     StudySession[]
  testResults       TestResult[]
  streakHistory     StreakHistory[]
  revisionPlans     RevisionPlan[]
  weakAreas         WeakArea[]
  achievements      Achievement[]
  notifications     Notification[]
  bookmarks         Bookmark[]
}

model Job {
  id            Int        @id @default(autoincrement())
  title         String     @db.VarChar(500)
  organization  String     @db.VarChar(500)
  category      String     @db.VarChar(100)
  subcategory   String?    @db.VarChar(100)
  description   String?    @db.Text
  eligibility   String?    @db.Text
  ageLimit      String?    @db.VarChar(200)
  salary        String?    @db.VarChar(500)
  selectionProcess String? @db.Text
  examPattern   String?    @db.Text
  vacancies     String?    @db.VarChar(100)
  officialWebsite String?  @db.VarChar(500)
  applyLink     String?    @db.VarChar(500)
  examDate      DateTime?
  lastDate      DateTime?
  cutoffs       String?    @db.Text
  previousYearTrends String? @db.Text
  importantDates String?   @db.Text
  status        String?    @default("active") @db.VarChar(50)
  createdAt     DateTime   @default(now())
}

model StudyPlan {
  id         Int      @id @default(autoincrement())
  userId     Int
  exam       String   @db.VarChar(255)
  examDate   DateTime
  planType   String   @default("auto") @db.VarChar(50)
  planJson   Json
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
}

model Note {
  id         Int      @id @default(autoincrement())
  userId     Int
  title      String   @db.VarChar(500)
  content    String   @db.Text
  subject    String?  @db.VarChar(100)
  tags       String?  @db.VarChar(500)
  color      String?  @default("blue") @db.VarChar(50)
  isPinned   Boolean  @default(false)
  aiSummary  String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id])
}

model StudySession {
  id         Int      @id @default(autoincrement())
  userId     Int
  duration   Int
  type       String   @default("pomodoro") @db.VarChar(50)
  subject    String?  @db.VarChar(100)
  focusScore Int?     @default(0)
  date       DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
}

model MockTest {
  id          Int      @id @default(autoincrement())
  title       String   @db.VarChar(255)
  subject     String?  @db.VarChar(100)
  category    String?  @db.VarChar(100)
  duration    Int      @default(60)
  totalMarks  Int      @default(100)
  totalQuestions Int   @default(50)
  questions   Json
  isSectional Boolean  @default(false)
  isPreviousYear Boolean @default(false)
  difficulty  String?  @default("medium") @db.VarChar(50)
  createdAt   DateTime @default(now())
}

model TestResult {
  id            Int      @id @default(autoincrement())
  userId        Int
  testId        Int
  score         Int
  totalMarks    Int
  correctAnswers Int
  incorrectAnswers Int
  unanswered    Int
  timeTaken     Int
  subjectWiseScores Json?
  answers       Json?
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id])
}

model StreakHistory {
  id         Int      @id @default(autoincrement())
  userId     Int
  date       DateTime
  studied    Boolean  @default(false)
  minutes    Int      @default(0)
  user       User     @relation(fields: [userId], references: [id])

  @@unique([userId, date])
}

model RevisionPlan {
  id         Int      @id @default(autoincrement())
  userId     Int
  planType   String   @db.VarChar(50)
  planJson   Json
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
}

model WeakArea {
  id         Int      @id @default(autoincrement())
  userId     Int
  subject    String   @db.VarChar(100)
  topic      String?  @db.VarChar(255)
  score      Float?
  suggestions String? @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id])
}

model Achievement {
  id         Int      @id @default(autoincrement())
  userId     Int
  badge      String   @db.VarChar(100)
  description String  @db.Text
  xpRewarded Int      @default(0)
  unlockedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
}

model Notification {
  id         Int      @id @default(autoincrement())
  userId     Int
  type       String   @db.VarChar(50)
  title      String   @db.VarChar(255)
  message    String   @db.Text
  isRead     Boolean  @default(false)
  link       String?  @db.VarChar(500)
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
}

model Bookmark {
  id         Int      @id @default(autoincrement())
  userId     Int
  type       String   @db.VarChar(50)
  referenceId Int
  title      String?  @db.VarChar(255)
  url        String?  @db.VarChar(500)
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
}

model CurrentAffair {
  id          Int      @id @default(autoincrement())
  title       String   @db.VarChar(500)
  description String?  @db.Text
  category    String?  @db.VarChar(100)
  date        DateTime
  source      String?  @db.VarChar(255)
  url         String?  @db.VarChar(500)
  tags        String?  @db.VarChar(500)
  createdAt   DateTime @default(now())
}

model ChatHistory {
  id         Int      @id @default(autoincrement())
  userId     Int
  message    String   @db.Text
  response   String   @db.Text
  createdAt  DateTime @default(now())
}

model Syllabus {
  id          Int      @id @default(autoincrement())
  exam        String   @db.VarChar(255)
  subject     String   @db.VarChar(255)
  topic       String   @db.VarChar(500)
  subtopics   String?  @db.Text
  weightage   Float?
  difficulty  String?  @default("medium") @db.VarChar(50)
  orderIndex  Int      @default(0)
}
